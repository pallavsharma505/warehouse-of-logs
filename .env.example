# API key for authenticating log ingestion requests
API_KEY=dev-api-key

# Admin credentials for dashboard login
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# Optional: JWT secret (auto-generated if not set)
# JWT_SECRET=your-secret-here

# Service ports
COLLECTOR_PORT=7001
API_PORT=7002

# Optional: custom path for the SQLite database file
# DATABASE_PATH=/path/to/logs.sqlite
